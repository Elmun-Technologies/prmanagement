# ══════════════════════════════════════════════════════════════════
# MoySklad Launch — Environment Variables
# ══════════════════════════════════════════════════════════════════
#
# 1. Go to https://supabase.com → Create new project
# 2. Project Settings → API → copy URL and anon key
# 3. Copy this file to .env.local and fill in your values
# 4. In Netlify: Site settings → Environment variables → add both
#
# ══════════════════════════════════════════════════════════════════

# Supabase Project URL (e.g. https://abcdefgh.supabase.co)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anonymous Key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
